    "eslint": "^9.39.4",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.0.268",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/css": "^1.20.0",
    "@vanilla-extract/vite-plugin": "^5.2.1",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^26.1.0",
    "sass": "^1.77.8",
